# ============================================================
# AI Multi-Studio — Environment Variables Template
# ============================================================
# Copy this file to .env.local and fill in every value.
# .env.local is git-ignored — never commit real keys.
#
# Setup order:
#   1. Appwrite Cloud  →  https://cloud.appwrite.io  (free)
#   2. Google AI Studio →  https://aistudio.google.com  (free, no credit card)
#   3. AssemblyAI      →  https://www.assemblyai.com   (free tier: 5h/month)
# ============================================================

# ============================================================
# APPWRITE — PUBLIC (safe to expose in browser bundle)
# Source: Appwrite Console → Project Overview
# ============================================================

NEXT_PUBLIC_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1

# Source: Appwrite Console → Overview → Project ID
NEXT_PUBLIC_APPWRITE_PROJECT_ID=

# Source: Appwrite Console → Databases → multi-studio → Database ID
NEXT_PUBLIC_APPWRITE_DB_ID=

# Source: Appwrite Console → Databases → multi-studio → profiles → Settings → Collection ID
NEXT_PUBLIC_APPWRITE_PROFILES_COLLECTION_ID=

# Source: Appwrite Console → Databases → multi-studio → projects → Settings → Collection ID
NEXT_PUBLIC_APPWRITE_PROJECTS_COLLECTION_ID=

# Source: Appwrite Console → Databases → multi-studio → outputs → Settings → Collection ID
NEXT_PUBLIC_APPWRITE_OUTPUTS_COLLECTION_ID=

# Source: Appwrite Console → Databases → multi-studio → schedules → Settings → Collection ID
NEXT_PUBLIC_APPWRITE_SCHEDULES_COLLECTION_ID=

# Source: Appwrite Console → Storage → audio-uploads → Settings → Bucket ID
NEXT_PUBLIC_APPWRITE_STORAGE_BUCKET_ID=

# ============================================================
# SERVER-ONLY — NEVER prefix with NEXT_PUBLIC_
# These values must NOT appear in the browser bundle (NFR-02)
# ============================================================

# Source: Appwrite Console → Settings → API Keys → Create Key
# Required scopes: databases.read, databases.write, storage.read, storage.write, users.read
APPWRITE_API_KEY=

# Source: https://aistudio.google.com → Get API key → Create API key
# Free tier: 1,500 requests/day, 1M tokens/minute — no credit card required
# See: docs/DECISIONS.md DEC-16
GOOGLE_AI_API_KEY=

# Source: https://www.assemblyai.com/dashboard → API Keys
# Free tier: ~5 hours of audio transcription/month
ASSEMBLYAI_API_KEY=
