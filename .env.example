# Copy this file to .env.local and fill in your values.

# ─── Appwrite (public — safe in client bundle) ───────────────────────────────
NEXT_PUBLIC_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
NEXT_PUBLIC_APPWRITE_PROJECT_ID=your_project_id

# ─── Appwrite Collection / Storage IDs (public) ──────────────────────────────
NEXT_PUBLIC_APPWRITE_DB_ID=your_database_id
NEXT_PUBLIC_APPWRITE_PROFILES_COLLECTION_ID=profiles
NEXT_PUBLIC_APPWRITE_PROJECTS_COLLECTION_ID=projects
NEXT_PUBLIC_APPWRITE_OUTPUTS_COLLECTION_ID=outputs
NEXT_PUBLIC_APPWRITE_SCHEDULES_COLLECTION_ID=schedules
NEXT_PUBLIC_APPWRITE_STORAGE_BUCKET_ID=audio-uploads

# ─── Appwrite Server SDK (server-only — NEVER expose to client) ───────────────
APPWRITE_API_KEY=your_appwrite_server_api_key

# ─── AI Services (server-only) ───────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key
ASSEMBLYAI_API_KEY=your_assemblyai_api_key
